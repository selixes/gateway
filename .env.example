# =========================================================================
# Selixes: The AI Reliability Layer - Environment Configuration
# =========================================================================
# Copy this file to `.env` before running the stack.
# $ cp .env.example .env
# =========================================================================

# -------------------------------------------------------------------------
# 1. External Dependencies (Required for Core Features)
# -------------------------------------------------------------------------

# OpenAI API Key (Required for default routing & failovers)
# Get yours here: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj_REPLACE_WITH_YOUR_OPENAI_KEY

# Anthropic API Key (Required if you want Anthropic as a fallback)
# Get yours here: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03_REPLACE_WITH_YOUR_ANTHROPIC_KEY

# Clerk Authentication Keys (Required for Dashboard access)
# Get these from your Clerk dashboard: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_CLERK_SECRET_KEY
CLERK_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_CLERK_WEBHOOK_SECRET

# Pinecone Vector Database (Required for Semantic Caching)
# Get yours here: https://app.pinecone.io/
PINECONE_API_KEY=REPLACE_WITH_YOUR_PINECONE_KEY
PINECONE_INDEX=selixes-semantic-cache

# -------------------------------------------------------------------------
# 2. Local Infrastructure Defaults (Safe to leave as-is for local dev)
# -------------------------------------------------------------------------

# Global Environment
NODE_ENV=development

# Postgres Configuration
POSTGRES_USER=akra
POSTGRES_PASSWORD=akrapassword
POSTGRES_DB=akra_flowops
DATABASE_URL="postgresql://akra:akrapassword@postgres:5432/akra_flowops?schema=public"

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# App URLs & Ports
PORT=4000
API_URL=http://localhost:4000
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# -------------------------------------------------------------------------
# 3. Security & Telemetry Secrets (Safe defaults for local dev)
# -------------------------------------------------------------------------
# Used for encrypting sensitive telemetry data in the DB
REPLAY_CRYPTO_SECRET=a_very_secure_32_byte_string_replace_in_prod

# Developer bypass token for local CLI testing (Optional)
DEV_BYPASS_TOKEN=selixes_local_dev_token
