# ─── Selixes Gateway — Environment Variables ───────────────────────────────
# Copy this file to apps/api/.env and fill in your values.
# Never commit .env files — they are gitignored.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://selixes:changeme@localhost:5432/selixes

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Clerk Auth ──────────────────────────────────────────────────────────────
# Get these from https://clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_your_key_here
CLERK_WEBHOOK_SECRET=whsec_your_secret_here

# ── LLM Upstream Providers ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Replay Vault Encryption ─────────────────────────────────────────────────
# 32+ character random string — used to AES-256-GCM encrypt stored traces
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REPLAY_CRYPTO_SECRET=generate_a_32_byte_hex_string_here

# ── Optional Alerts ─────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
ALERT_EMAIL=

# ── Development Only ─────────────────────────────────────────────────────────
# Set a secure random token to bypass Clerk auth in local development.
# NEVER set this in a production or staging environment.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEV_BYPASS_TOKEN=
